# FastAPI Backend Configuration
# Change to your FastAPI backend IP/hostname
# IMPORTANT: Expo only exposes env vars prefixed with EXPO_PUBLIC_
#
# Local testing with emulator/simulator: http://localhost:8000
# Local testing on network device: http://<your-machine-ip>:8000
# Production: https://your-server-domain.com
EXPO_PUBLIC_API_BASE_URL=http://192.168.8.119:8000
